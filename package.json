{
  "name": "community-desktop",
  "version": "1.1.1",
  "description": "Podwires Community Desktop — native wrapper for community.podwires.com.",
  "main": "src/main.js",
  "author": {
    "name": "Podwires",
    "email": "hello@podwires.com",
    "url": "https://community.podwires.com"
  },
  "homepage": "https://community.podwires.com",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux",
    "dist:all": "electron-builder -mwl"
  },
  "devDependencies": {
    "electron": "^32.0.0",
    "electron-builder": "^25.0.0"
  },
  "dependencies": {
    "electron-store": "^8.2.0"
  },
  "build": {
    "appId": "com.podwires.community",
    "productName": "PodwiresCommunity",
    "copyright": "Copyright © 2026 Podwires",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "src/**/*",
      "build/icon*.png",
      "package.json"
    ],
    "protocols": [
      {
        "name": "Podwires Community",
        "schemes": ["podwires-community"]
      }
    ],
    "mac": {
      "category": "public.app-category.social-networking",
      "target": [
        { "target": "dmg",  "arch": ["arm64", "x64"] },
        { "target": "zip",  "arch": ["arm64", "x64"] }
      ],
      "icon": "build/icon.png",
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "darkModeSupport": true
    },
    "dmg": {
      "title": "PodwiresCommunity ${version}",
      "icon": "build/icon.png"
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "build/icon.png",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.exe"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Podwires Community"
    },
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb",      "arch": ["x64"] }
      ],
      "icon": "build/icon.png",
      "category": "Network;InstantMessaging"
    }
  }
}
